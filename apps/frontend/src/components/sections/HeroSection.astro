---
import WalletConnect from "../../islands/WalletConnect";
---

<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 pt-24 pb-20">
  <!-- glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <!-- badge -->
  <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-lg border border-purple-500/30 text-purple-400 text-xs font-medium mb-8 relative z-10">
    <span class="w-1.5 h-1.5 rounded-full bg-purple-400 animate-pulse"></span>
    Live on Base Sepolia Testnet
  </div>

  <!-- headline -->
  <h1 class="relative z-10 text-5xl sm:text-6xl lg:text-7xl font-black max-w-4xl mx-auto leading-[1.05] tracking-tight">
    The Premier AI Yield Agent<br/>
    <span class="text-purple-400">for DeFi on Base</span>
  </h1>

  <p class="relative z-10 mt-6 text-lg text-white/50 max-w-xl mx-auto leading-relaxed">
    Non-custodial AI agent. Set your strategy once in plain English.
    Agent auto-optimizes yield across Aave &amp; Morpho — 24/7.
  </p>

  <!-- CTAs -->
  <div class="relative z-10 mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
    <WalletConnect client:load variant="hero" redirectToDashboard={true} />
    <a href="#about"
      class="px-6 py-3 rounded-lg border border-white/15 text-white/70 text-sm font-medium hover:border-white/30 hover:text-white transition-all">
      Learn more
    </a>
  </div>

  <!-- stats -->
  <div class="relative z-10 mt-20 grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-3xl mx-auto w-full">
    {[
      { value: "Up to 12%",     label: "APY on stablecoins" },
      { value: "6h",            label: "Auto-rebalance cycle" },
      { value: "Non-custodial", label: "You keep control" },
      { value: "24/7",          label: "Autonomous AI agent" },
    ].map((s) => (
      <div class="rounded-xl border border-white/8 px-4 py-5 text-center"
        style="background: rgba(255,255,255,0.03);">
        <p class="text-purple-400 font-bold text-xl">{s.value}</p>
        <p class="text-white/40 text-xs mt-1">{s.label}</p>
      </div>
    ))}
  </div>
</section>
