---
import { STRINGS } from "../lib/strings";
---

<footer class="border-t border-slate-200 dark:border-slate-800 py-8 px-6 mt-20">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
    <div class="flex items-center gap-2">
      <span class="text-cyan-400 font-bold">DeFAI</span>
      <span class="dark:text-white font-bold">YieldGuard</span>
      <span class="text-slate-400">— Hackathon MVP 2026</span>
    </div>
    <div class="flex items-center gap-6">
      <a href="https://base.org" target="_blank" rel="noopener" class="hover:text-cyan-400 transition-colors">
        Built on Base
      </a>
      <a href="https://chain.link" target="_blank" rel="noopener" class="hover:text-cyan-400 transition-colors">
        Powered by Chainlink
      </a>
      <a href="https://safe.global" target="_blank" rel="noopener" class="hover:text-cyan-400 transition-colors">
        Safe Wallet
      </a>
    </div>
