---
export const prerender = false;
import DashboardShell from "../../islands/dashboard/DashboardShell";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="DeFAI YieldGuard — AI Yield Agent Dashboard on Base" />
    <title>Dashboard — DeFAI YieldGuard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/src/styles/global.css" />
    <!-- Apply theme before paint to avoid flash -->
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t === "light") document.documentElement.classList.remove("dark");
      else document.documentElement.classList.add("dark");
    </script>
  </head>
  <body>
    <DashboardShell client:load />
  </body>
</html>
