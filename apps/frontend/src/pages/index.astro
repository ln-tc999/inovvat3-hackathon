---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import WalletConnect from "../islands/WalletConnect";
import { Shield, Cpu, Zap, ArrowRight } from "lucide-react";
import { STRINGS } from "../lib/strings";
---

<MainLayout>
  <!-- Nav -->
  <nav class="sticky top-0 z-40 bg-white/80 dark:bg-slate-950/80 backdrop-blur border-b border-slate-200 dark:border-slate-800 px-6 py-3">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="/" class="flex items-center gap-2" aria-label="DeFAI YieldGuard home">
        <span class="text-cyan-400 font-bold text-lg">DeFAI</span>
        <span class="dark:text-white font-bold text-lg">YieldGuard</span>
      </a>
      <div class="flex items-center gap-4">
        <a href="#how-it-works" class="hidden sm:block text-sm text-slate-500 hover:text-cyan-400 transition-colors">
          How it works
        </a>
        <WalletConnect client:load variant="header" redirectToDashboard={true} />
      </div>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <Hero>
      <WalletConnect slot="cta" client:load variant="hero" redirectToDashboard={true} />
    </Hero>

    <!-- How it works -->
    <section id="how-it-works" class="py-20 px-6 border-t border-slate-200 dark:border-slate-800">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl font-bold text-center text-slate-900 dark:text-white mb-12">
          How it works
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            {
              icon: "wallet",
              step: "01",
              title: STRINGS.feature1Title,
              desc: STRINGS.feature1Desc,
            },
            {
              icon: "cpu",
              step: "02",
              title: STRINGS.feature2Title,
              desc: STRINGS.feature2Desc,
            },
            {
              icon: "shield",
              step: "03",
              title: STRINGS.feature3Title,
              desc: STRINGS.feature3Desc,
            },
          ].map((item) => (
            <div class="card relative">
              <span class="text-5xl font-black text-slate-100 dark:text-slate-800 absolute top-4 right-5 select-none">
                {item.step}
              </span>
              <div class="w-10 h-10 rounded-lg bg-cyan-400/10 border border-cyan-400/20 flex items-center justify-center mb-4">
                {item.icon === "wallet" && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00D4FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>}
                {item.icon === "cpu" && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00D4FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2M15 20v2M2 15h2M20 15h2M2 9h2M20 9h2M9 2v2M9 20v2"/></svg>}
                {item.icon === "shield" && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00D4FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>}
              </div>
              <h3 class="font-semibold text-slate-900 dark:text-white mb-2">{item.title}</h3>
              <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>

        <!-- CTA bottom -->
        <div class="mt-12 text-center">
          <a href="/dashboard" class="btn-primary text-base px-8 py-3 inline-flex">
            Open Dashboard
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Protocol logos / trust bar -->
    <section class="py-12 px-6 border-t border-slate-200 dark:border-slate-800">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-xs text-slate-400 uppercase tracking-widest mb-6">Powered by</p>
        <div class="flex flex-wrap items-center justify-center gap-8 text-slate-400 text-sm font-medium">
          {["Aave V3", "Morpho Blue", "Chainlink Functions", "Chainlink Automation", "Safe Wallet", "Base Chain"].map((name) => (
            <span class="hover:text-cyan-400 transition-colors cursor-default">{name}</span>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</MainLayout>
